#!/usr/bin/env bash
#
# Cut a release in one shot:
#
#   ./scripts/release
#
# The version is the single source of truth in irij.toml ([project] version) —
# the website's own SemVer. Bump it there (commit + push to main) first, then
# run this. Pushing v<version> triggers .github/workflows/release.yml to build
# server.jar and publish the release.
#
# Re-releasing the same version fails (the tag already exists), so you MUST bump
# irij.toml before each release. The Irij ENGINE version shown on the page is a
# separate thing, auto-stamped from the toolchain at build time.
#
# Run from a clean, up-to-date checkout of main.
set -euo pipefail
cd "$(dirname "$0")/.."

repo="aldebogdanov/irij.online"

# Read [project] version from irij.toml. Section-aware so a stray `version =`
# key in another table can't shadow it.
version=$(awk -F'"' '
  /^[[:space:]]*\[/                                              { section = $0 }
  section ~ /\[project\]/ && /^[[:space:]]*version[[:space:]]*=/ { print $2; exit }
' irij.toml)

if [ -z "$version" ]; then
  echo "error: could not read [project] version from irij.toml." >&2
  exit 1
fi
if ! printf '%s' "$version" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$'; then
  echo "error: irij.toml version '$version' is not SemVer MAJOR.MINOR.PATCH." >&2
  exit 1
fi
tag="v${version}"

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" != "main" ]; then
  echo "error: on branch '$branch', expected 'main'." >&2
  exit 1
fi
if [ -n "$(git status --porcelain)" ]; then
  echo "error: working tree is not clean — commit or stash first." >&2
  exit 1
fi

git fetch --quiet origin main
if [ "$(git rev-parse HEAD)" != "$(git rev-parse origin/main)" ]; then
  echo "error: local main != origin/main. Sync first (git pull --ff-only)." >&2
  exit 1
fi

if git rev-parse -q --verify "refs/tags/${tag}" >/dev/null \
   || git ls-remote --exit-code --tags origin "${tag}" >/dev/null 2>&1; then
  echo "error: ${tag} already released. Bump 'version' in irij.toml first." >&2
  exit 1
fi

echo "Releasing ${tag} (from irij.toml) ..."
git tag "${tag}"
git push origin "${tag}"
echo "Pushed ${tag}. Watch the build:  gh run watch --repo ${repo}"
echo "Release will appear at: https://github.com/${repo}/releases/tag/${tag}"
