#!/usr/bin/env bash
#
# Cut a release in one shot:
#
#   ./scripts/release
#
# Commit-count versioning. The 2-part base (MAJOR.MINOR) is the single source
# of truth in irij.toml ([project] version); the released version is
# base + "." + the git commit count — you never hand-pick the patch. Bump the
# base in irij.toml only for a MAJOR/MINOR release; otherwise just land commits
# on main and run this. Pushing v<version> triggers .github/workflows/release.yml
# to build server.jar and publish the release.
#
# Each commit advances the patch, so re-running on the same commit fails (the
# tag already exists) — land a new commit to cut the next patch. The Irij ENGINE
# version shown on the page is separate (auto-stamped from the toolchain).
#
# Run from a clean, up-to-date checkout of main.
set -euo pipefail
cd "$(dirname "$0")/.."

repo="aldebogdanov/irij.online"

# Read the 2-part base (MAJOR.MINOR) from irij.toml [project] version.
# Section-aware so a stray `version =` key in another table can't shadow it.
base=$(awk -F'"' '
  /^[[:space:]]*\[/                                              { section = $0 }
  section ~ /\[project\]/ && /^[[:space:]]*version[[:space:]]*=/ { print $2; exit }
' irij.toml)

if [ -z "$base" ]; then
  echo "error: could not read [project] version from irij.toml." >&2
  exit 1
fi
if ! printf '%s' "$base" | grep -Eq '^[0-9]+\.[0-9]+$'; then
  echo "error: irij.toml version '$base' must be a 2-part MAJOR.MINOR base" >&2
  echo "       (the patch is the git commit count, appended automatically)." >&2
  exit 1
fi

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" != "main" ]; then
  echo "error: on branch '$branch', expected 'main'." >&2
  exit 1
fi
if [ -n "$(git status --porcelain)" ]; then
  echo "error: working tree is not clean — commit or stash first." >&2
  exit 1
fi

git fetch --quiet origin main
if [ "$(git rev-parse HEAD)" != "$(git rev-parse origin/main)" ]; then
  echo "error: local main != origin/main. Sync first (git pull --ff-only)." >&2
  exit 1
fi

# Patch = commit count on the synced main HEAD. Version = base.patch.
version="${base}.$(git rev-list --count HEAD)"
tag="v${version}"

if git rev-parse -q --verify "refs/tags/${tag}" >/dev/null \
   || git ls-remote --exit-code --tags origin "${tag}" >/dev/null 2>&1; then
  echo "error: ${tag} already released. The patch is the commit count —" >&2
  echo "       land a new commit on main to cut the next patch." >&2
  exit 1
fi

echo "Releasing ${tag} (base ${base} + commit count) ..."
git tag "${tag}"
git push origin "${tag}"
echo "Pushed ${tag}. Watch the build:  gh run watch --repo ${repo}"
echo "Release will appear at: https://github.com/${repo}/releases/tag/${tag}"
